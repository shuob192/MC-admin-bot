# Discord Bot token (Discord Developer Portal で取得)
DISCORD_TOKEN=your_discord_bot_token_here

# Jetson の Tailscale IP + エージェントのポート番号
AGENT_URL=http://100.x.x.x:8000

# agent/.env と同じ値を設定する
AGENT_API_KEY=replace_with_random_hex_key

# minecraft-sv チャンネルの ID (Discord で開発者モードを有効にして右クリック → ID をコピー)
MINECRAFT_CHANNEL_ID=123456789012345678

# このロールを持つユーザーのみが管理コマンドを使えるようになる
OPERATOR_ROLE_NAME=MC-Operator
