[Unit]
Description=Minecraft Bot Agent
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/MC_server_logbot/agent
ExecStart=/home/ubuntu/MC_server_logbot/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
EnvironmentFile=/home/ubuntu/MC_server_logbot/agent/.env

[Install]
WantedBy=multi-user.target
